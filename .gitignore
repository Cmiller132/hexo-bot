runs/*
!runs/.gitkeep
target/
__pycache__/
.pytest_cache/
*.pyc
*.so
*.pyd
.venv/
*.log
.claude/

# Showcase deployment: secrets and mounted model dir (never committed)
apps/showcase/.env
apps/showcase/deploy/models/*
!apps/showcase/deploy/models/.gitkeep

# Data caches — keep only scaffolding .gitkeep files
data/*
!data/*/
data/*/*
!data/*/.gitkeep
