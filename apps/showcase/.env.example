# Showcase secrets — copy to `.env` next to docker-compose.yml and fill in.
# `.env` is gitignored; keep it chmod 600. These are the ONLY secrets in the
# stack.

# Cloudflare tunnel token. Cloudflare dashboard -> Zero Trust -> Networks ->
# Tunnels -> create (or open) the tunnel -> the docker-format connector
# command contains the token. Route the tunnel's public hostname to
# http://app:8000.
TUNNEL_TOKEN=

# Stable salt for hashed client IPs (SHOWCASE_IP_SALT in
# server/showcase/config.py). The DB stores salted hashes only; without a
# stable value a random per-boot salt is used and per-IP history is orphaned
# on every restart. Generate once:  openssl rand -hex 32
SHOWCASE_IP_SALT=
