# hexfield_eq ray-tap wave-1 ARM A5 (L-subsumption, the load-bearing arm) —
# SPEC_RAYTAP_CONV.md §6.3: v2 features, ray-tap BOTH, layout CCACCACA — the
# live layout with its 3 L blocks removed (C/A counts preserved, ends with
# 'A'). Does ray-tap subsume ray ATTENTION? Read on both axes: strength AND
# serve throughput ("equal strength, smaller layout, faster serve" is a
# recordable outcome). Training needs no extra plumbing (the Rust expand emits
# raylen unconditionally); serve raylen staging is un-gated on RAYTAP != 0.

HEXFIELD_EQ_CHANNELS=192
HEXFIELD_EQ_GROUP_ORDER=12
HEXFIELD_EQ_C_ORBIT=16
HEXFIELD_EQ_ATTENTION_HEADS=3
HEXFIELD_EQ_SUPPORT_RADIUS=4

HEXFIELD_EQ_TRUNK=CCACCACA
HEXFIELD_EQ_REG_LANE=1
HEXFIELD_EQ_REG_TOK_READ=0

# Wave-1 knobs (the A5 deltas: features v2 + ray-tap both + L removed).
HEXFIELD_EQ_FEATURE_VERSION=2
HEXFIELD_EQ_RAYTAP=both
