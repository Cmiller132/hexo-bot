# Line-ending normalization: WSL/Linux users get LF checkouts regardless of the
# committer's platform. The PM renormalizes at commit time.
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.service text eol=lf
*.md text eol=lf

# Model weights via Git LFS.
models/*.pt filter=lfs diff=lfs merge=lfs -text
