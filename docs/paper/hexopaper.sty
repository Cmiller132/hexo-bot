% Tectonic's cached article class contains the 11pt size file but not the
% 10pt one.  Use the available class and set a conventional 10/12 body size.
\makeatletter
\renewcommand\normalsize{%
  \@setfontsize\normalsize{10pt}{11.3pt}%
  \abovedisplayskip 10pt plus 2pt minus 5pt%
  \abovedisplayshortskip 0pt plus 3pt%
  \belowdisplayshortskip 6pt plus 3pt minus 3pt%
  \belowdisplayskip \abovedisplayskip%
  \let\@listi\@listI}
% Paragraph columns carry prose; leave a flexible right edge rather than
% stretching short lines in narrow table cells.
\let\hex@arrayparboxrestore\@arrayparboxrestore
\def\@arrayparboxrestore{%
  \hex@arrayparboxrestore
  \rightskip=0pt plus 1fil\relax}
\makeatother
\AtBeginDocument{\normalsize}

\definecolor{HexLink}{RGB}{42,72,92}
\definecolor{HexCite}{RGB}{82,66,92}
\definecolor{HexURL}{RGB}{62,82,72}
\RequirePackage[
  colorlinks=true,
  linkcolor=HexLink,
  citecolor=HexCite,
  urlcolor=HexURL
]{hyperref}
\RequirePackage[capitalise,nameinlink]{cleveref}
\urlstyle{same}

\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}
\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{fact}[theorem]{Fact}
\theoremstyle{remark}
\newtheorem*{remark}{Remark}
\newtheorem*{example}{Example}
\newtheorem*{plainterms}{In plain terms}

\crefname{fact}{Fact}{Facts}
\Crefname{fact}{Fact}{Facts}
\crefname{plainterms}{in plain terms}{in plain terms}

